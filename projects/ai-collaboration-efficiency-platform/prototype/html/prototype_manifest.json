  "source_artifact_notes": [
    "00_page_flow.png and 10_interaction_notes.png are used as interpretation references, not rebuilt as product screens.",
    "01_dashboard.png through 09_permissions_risk.png are rebuilt as editable HTML screens."
  ],
  "screen_inventory": [
    {
      "screen_id": "dashboard",
      "screen_name": "Dashboard 工作台",
      "purpose": "Show role-specific work entry points, pending tasks, common Skills, risks, and team summary.",
      "entry_points": [
        "Open prototype",
        "sidebar Dashboard"
      ],
      "primary_actions": [
        "发起任务",
        "查看 Review",
        "打开任务",
        "打开 Skill"
      ],
      "states": [
        "normal",
        "risk_notice"
      ]
    },
    {
      "screen_id": "task-center",
      "screen_name": "任务中心 / 新建任务",
      "purpose": "Create a task, define input material, and run pre-execution checks before choosing a Skill.",
      "entry_points": [
        "Dashboard 发起任务",
        "topbar 新建任务",
        "sidebar 任务中心"
      ],
      "primary_actions": [
        "保存草稿",
        "继续选择 Skill"
      ],
      "states": [
        "normal",
        "precheck_pass",
        "risk_warn"
      ]
    },
    {
      "screen_id": "skill-run",
      "screen_name": "Skill 调用 / 结果预览",
      "purpose": "Configure Skill, run execution, preview candidate results, and submit Review.",
      "entry_points": [
        "任务中心 继续选择 Skill",
        "Dashboard Skill card"
      ],
      "primary_actions": [
        "开始处理",
        "提交 Review"
      ],
      "states": [
        "ready",
        "loading",
        "candidate_result",
        "review_required"
      ]
    },
    {
      "screen_id": "review-center",
      "screen_name": "Review 多人评审中心",
      "purpose": "Review risky or high-value AI outputs with score dimensions and audit trail.",
      "entry_points": [
        "Dashboard 查看 Review",
        "Skill 调用提交 Review",
        "sidebar Review"
      ],
      "primary_actions": [
        "通过",
        "退回",
        "复审"
      ],
      "states": [
        "pending",
        "approved",
        "returned",
        "recheck"
      ]
    },
    {
      "screen_id": "efficiency",
      "screen_name": "员工效率看板",
      "purpose": "Show explainable contribution metrics, evidence chain, and non-performance boundary.",
      "entry_points": [
        "Review 通过",
        "sidebar 效率看板"
      ],
      "primary_actions": [
        "查看证据链",
        "发起申诉"
      ],
      "states": [
        "normal",
        "evidence_drawer"
      ]
    },
    {
      "screen_id": "skill-admin",
      "screen_name": "Skill 管理与权重配置",
      "purpose": "Manage Skill lifecycle, risk level, Review rules, weights, and anti-gaming limits.",
      "entry_points": [
        "Dashboard Skill 管理",
        "sidebar Skill 管理"
      ],
      "primary_actions": [
        "测试 Skill",
        "申请上架"
      ],
      "states": [
        "published",
        "testing",
        "approval_pending"
      ]
    },
    {
      "screen_id": "calculation",
      "screen_name": "权重计算引擎",
      "purpose": "Explain how contribution score, Skill weight, Review dimensions, caps, and anti-gaming coefficients are calculated and persisted.",
      "entry_points": [
        "sidebar 权重计算",
        "效率看板 查看计算口径",
        "Skill 管理 查看权重公式"
      ],
      "primary_actions": [
        "返回 Skill 管理",
        "查看效率看板"
      ],
      "states": [
        "formula_explanation",
        "score_breakdown",
        "engineering_snapshot"
      ]
    },
    {
      "screen_id": "knowledge",
      "screen_name": "知识沉淀 / 组织资产库",
      "purpose": "Publish reviewed outputs as Prompt, SOP, Case, failure pattern, or review note assets.",
      "entry_points": [
        "sidebar 知识库",
        "Review pass knowledge action"
      ],
      "primary_actions": [
        "发布知识",
        "查看复用",
        "打开沉淀规则"
      ],
      "states": [
        "normal",
        "published",
        "review_rules"
      ]
    },
    {
      "screen_id": "reports",
      "screen_name": "报表导出中心",
      "purpose": "Configure export scope, sensitive detail policy, and audit report exports.",
      "entry_points": [
        "sidebar 报表导出",
        "效率看板 export action"
      ],
      "primary_actions": [
        "预览",
        "导出 Excel / PDF"
      ],
      "states": [
        "preview",
        "export_created"
      ]
    },
    {
      "screen_id": "risk-admin",
      "screen_name": "权限与风控",
      "purpose": "Configure RBAC, P0/P1/P2 risk rules, and audit logs.",
      "entry_points": [
        "sidebar 权限与风控",
        "report export audit route"
      ],
      "primary_actions": [
        "保存草稿",
        "二次确认"
      ],
      "states": [
        "normal",
        "modal_confirm",
        "audit_written"
      ]
    }
  ],
  "multi_page_structure": {
    "source_sequence_preserved": true,
    "derived_engineering_screen_added": "calculation",
    "shared_shell": true,
    "route_map": [
      {
        "nav_or_action": "sidebar Dashboard",
        "target_screen": "dashboard"
      },
      {
        "nav_or_action": "新建任务",
        "target_screen": "task-center"
      },
      {
        "nav_or_action": "继续选择 Skill",
        "target_screen": "skill-run"
      },
      {
        "nav_or_action": "提交 Review",
        "target_screen": "review-center"
      },
      {
        "nav_or_action": "Review 通过",
        "target_screen": "efficiency"
      },
      {
        "nav_or_action": "查看权重公式",
        "target_screen": "calculation"
      },
      {
        "nav_or_action": "导出报表",
        "target_screen": "risk-admin"
      }
    ]
  },
  "interaction_inventory": [
    {
      "interaction_id": "nav_switch_screen",
      "trigger": "sidebar or CTA with data-nav-target",
      "from_screen": "any",
      "result": "navigate",
      "target": "target screen"
    },
    {
      "interaction_id": "run_skill_loading",
      "trigger": "开始处理",
      "from_screen": "skill-run",
      "result": "state_change",
      "target": "candidate result box"
    },
    {
      "interaction_id": "review_approve",
      "trigger": "通过",
      "from_screen": "review-center",
      "result": "navigate",
      "target": "efficiency"
    },
    {
      "interaction_id": "open_evidence_drawer",
      "trigger": "查看证据链",
      "from_screen": "efficiency",
      "result": "drawer",
      "target": "contextDrawer"
    },
    {
      "interaction_id": "open_calculation_screen",
      "trigger": "查看计算口径 / 查看权重公式",
      "from_screen": "efficiency or skill-admin",
      "result": "navigate",
      "target": "calculation"
    },
    {
      "interaction_id": "export_report_audit",
      "trigger": "导出 Excel / PDF",
      "from_screen": "reports",
      "result": "navigate",
      "target": "risk-admin"
    },
    {
      "interaction_id": "confirm_risk_modal",
      "trigger": "二次确认",
      "from_screen": "risk-admin",
      "result": "modal",
      "target": "confirmRisk"
    }
  ],
  "route_context_transfer": [
    {
      "route_id": "dashboard_to_task",
      "trigger": "发起任务",
      "from_screen": "dashboard",
      "to_screen": "task-center",
      "transferred_context": [
        "source: dashboard",
        "default task creation intent"
      ],
      "return_path": "sidebar Dashboard"
    },
    {
      "route_id": "task_to_skill_run",
      "trigger": "继续选择 Skill",
      "from_screen": "task-center",
      "to_screen": "skill-run",
      "transferred_context": [
        "task name",
        "task type",
        "input material",
        "risk precheck"
      ],
      "return_path": "sidebar 任务中心"
    },
    {
      "route_id": "skill_run_to_review",
      "trigger": "提交 Review",
      "from_screen": "skill-run",
      "to_screen": "review-center",
      "transferred_context": [
        "candidate result",
        "saved hours",
        "initial contribution",
        "risk level"
      ],
      "return_path": "sidebar Skill 调用"
    },
    {
      "route_id": "review_to_efficiency",
      "trigger": "通过",
      "from_screen": "review-center",
      "to_screen": "efficiency",
      "transferred_context": [
        "approved score",
        "review history",
        "evidence chain"
      ],
      "return_path": "sidebar Review 评审"
    },
    {
      "route_id": "score_surface_to_calculation",
      "trigger": "查看计算口径 / 查看权重公式",
      "from_screen": "efficiency or skill-admin",
      "to_screen": "calculation",
      "transferred_context": [
        "formula version",
        "score breakdown",
        "weight source",
        "formula snapshot requirement"
      ],
      "return_path": "sidebar 效率看板 or sidebar Skill 管理"
    },
    {
      "route_id": "reports_to_risk_audit",
      "trigger": "导出 Excel / PDF",
      "from_screen": "reports",
      "to_screen": "risk-admin",
      "transferred_context": [
        "report template",
        "export scope",
        "sensitive detail policy"
      ],
      "return_path": "sidebar 报表导出"
    }
  ],
  "inline_editing": {
    "enabled": true,
    "trigger": "double_click_text",
    "save_behavior": "enter_or_blur",
    "cancel_behavior": "escape",
    "persistence": "none"
  },
  "editable_files": [
    {
      "path": "index.html",
      "purpose": "structure"
    },
    {
      "path": "styles.css",
      "purpose": "styles"
    },
    {
      "path": "app.js",
      "purpose": "interactions"
    },
    {
      "path": "standalone.html",
      "purpose": "single_file_handoff"
    },
    {
      "path": "prototype_manifest.json",
      "purpose": "manifest"
    },
    {
      "path": "open-mac.command",
      "purpose": "launcher"
    },
    {
      "path": "open-windows.bat",
      "purpose": "launcher"
    },
    {
      "path": "assets/reference/",
      "purpose": "reference_assets"
    }
  ],
  "platform_compatibility": {
    "supported_platforms": [
      "macOS",
      "Windows"
    ],
    "path_strategy": "relative_paths_only",
    "requires_server": false,
    "requires_dependencies": false,
    "open_entry": "index.html",
    "single_file_entry": "standalone.html",
    "helper_launchers": [
      "open-mac.command",
      "open-windows.bat"
    ],
    "handoff_rule": "Recommended handoff is the zip package; unzip it and open index.html. For one-file sharing use standalone.html.",
    "zip_package": "../ai-collaboration-efficiency-html-prototype.zip"
  },
