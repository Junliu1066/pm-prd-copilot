      "interaction_id": "inline_text_edit",
      "trigger": "双击普通文本",
      "from_screen": "any",
      "result": "form_feedback",
      "target": "原位编辑并本地保存"
    }
  ],
  "route_context_transfer": [
    {
      "route_id": "datasets_to_evaluations",
      "trigger": "查看评测",
      "from_screen": "datasets",
      "to_screen": "evaluations",
      "transferred_context": [
        "当前测试集",
        "Case 数量",
        "风险 Case 数量"
      ],
      "return_path": "左侧导航返回 Datasets"
    },
    {
      "route_id": "any_to_prompt_create",
      "trigger": "创建 Prompt",
      "from_screen": "any",
      "to_screen": "prompt-create",
      "transferred_context": [
        "当前评测上下文",
        "当前 Dataset",
        "选中失败 Case"
      ],
      "return_path": "创建页返回 Prompts"
    },
    {
      "route_id": "runs_to_review",
      "trigger": "提交人工评审",
      "from_screen": "runs",
      "to_screen": "review",
      "transferred_context": [
        "Run ID",
        "候选 Prompt 版本",
        "Dataset",
        "评测指标",
        "失败 Case"
      ],
      "return_path": "Review 页返回 Runs"
    },
    {
      "route_id": "evaluations_to_optimize",
      "trigger": "进入 Optimize",
      "from_screen": "evaluations",
      "to_screen": "optimize",
      "transferred_context": [
        "失败 Case",
        "评分项",
        "风险类型"
      ],
      "return_path": "左侧导航返回 Evaluations"
    },
    {
      "route_id": "optimize_to_compare",
      "trigger": "版本 Compare",
      "from_screen": "optimize",
      "to_screen": "compare",
      "transferred_context": [
        "候选版本",
        "基线版本",
        "回归测试结果"
      ],
      "return_path": "左侧导航返回 Optimize"
    }
  ],
  "inline_editing": {
    "enabled": true,
    "trigger": "double_click_text",
    "save_behavior": "enter_or_blur",
    "cancel_behavior": "escape",
    "persistence": "local_storage"
  },
  "editable_files": [
    {
      "path": "index.html",
      "purpose": "structure"
    },
    {
      "path": "styles.css",
      "purpose": "styles"
    },
    {
      "path": "app.js",
      "purpose": "interactions"
    },
