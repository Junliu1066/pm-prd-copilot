  "screen_inventory": [
    {
      "screen_id": "dashboard",
      "screen_name": "Dashboard 页面",
      "purpose": "工作台总览与快捷入口",
      "entry_points": [
        "左侧导航"
      ],
      "primary_actions": [
        "进入评测",
        "管理 Datasets",
        "进入 Optimize",
        "版本 Compare",
        "模型设置"
      ],
      "states": [
        "normal"
      ]
    },
    {
      "screen_id": "prompts",
      "screen_name": "Prompts 页面",
      "purpose": "Prompt 管理入口与创建入口",
      "entry_points": [
        "左侧导航"
      ],
      "primary_actions": [
        "创建 Prompt",
        "复制创建",
        "查看 Prompt"
      ],
      "states": [
        "normal"
      ]
    },
    {
      "screen_id": "prompt-create",
      "screen_name": "创建 Prompt 页面",
      "purpose": "从评测、Dataset 或失败 Case 上下文创建 Prompt 初稿",
      "entry_points": [
        "顶部创建 Prompt",
        "Prompts 页面创建 Prompt"
      ],
      "primary_actions": [
        "保存草稿",
        "发布版本",
        "发起测试",
        "进入评测",
        "进入优化"
      ],
      "states": [
        "draft"
      ]
    },
    {
      "screen_id": "datasets",
      "screen_name": "Datasets 页面",
      "purpose": "管理测试集、Case、评分规则与导入导出",
      "entry_points": [
        "默认打开",
        "左侧导航"
      ],
      "primary_actions": [
        "查看测试集",
        "新增 Case",
        "批量导入",
        "导出 Case"
      ],
      "states": [
        "normal",
        "selected_row"
      ]
    },
    {
      "screen_id": "dataset-detail",
      "screen_name": "Dataset 详情",
      "purpose": "承载测试集表格“查看”动作，展示测试集基础信息、Case 明细、评分规则、导入历史与快捷操作",
      "entry_points": [
        "Datasets 表格查看按钮",
        "Datasets 表格更多按钮"
      ],
      "primary_actions": [
        "编辑测试集",
        "发起评测",
        "导出测试集",
        "进入 Optimize",
        "进入 Compare"
      ],
      "states": [
        "normal",
        "context_from_selected_dataset"
      ]
    },
    {
      "screen_id": "dataset-edit",
      "screen_name": "编辑 Dataset",
      "purpose": "承载测试集表格“编辑”动作，展示可修改字段、评分权重与导入导出设置",
      "entry_points": [
        "Datasets 表格编辑按钮",
        "Dataset 详情编辑按钮"
      ],
      "primary_actions": [
        "保存变更",
        "返回详情"
      ],
      "states": [
        "form_editing"
      ]
    },
    {
      "screen_id": "models",
      "screen_name": "Models 页面",
      "purpose": "管理 Provider、凭证、连接日志与默认模型",
      "entry_points": [
        "左侧导航",
        "Dashboard 模型设置"
      ],
      "primary_actions": [
        "新增凭证",
        "测试连接",
        "保存设置"
      ],
      "states": [
        "normal",
        "online",
        "offline"
      ]
    },
    {
      "screen_id": "runs",
      "screen_name": "Runs 页面",
      "purpose": "配置并查看 Run 执行队列与详情",
      "entry_points": [
        "左侧导航",
        "顶部新建 Run"
      ],
      "primary_actions": [
        "开始运行",
        "失败重跑",
        "查看详情"
      ],
      "states": [
        "normal",
        "running",
        "completed"
      ]
    },
    {
      "screen_id": "review",
      "screen_name": "Review 人工评审",
      "purpose": "承载人工评审流程，展示版本指标、规则检查、Case 变更、评分、决策、评论和提交记录",
      "entry_points": [
        "左侧导航",
        "Runs 页面提交人工评审"
      ],
      "primary_actions": [
        "调整评分",
        "选择评审决策",
        "保存草稿",
        "提交评审",
        "返回 Optimize",
        "查看 Evaluations"
      ],
      "states": [
        "normal",
        "draft_saved",
        "submitted"
      ]
    },
    {
      "screen_id": "evaluations",
      "screen_name": "Evaluations 页面",
      "purpose": "查看评测指标、失败 Case 与风险分布",
      "entry_points": [
        "左侧导航",
        "Dashboard 查看评测"
      ],
      "primary_actions": [
        "查询",
        "查看失败 Case",
        "查看风险 Case"
      ],
      "states": [
        "normal",
        "risk_case"
      ]
    },
    {
      "screen_id": "optimize",
      "screen_name": "Optimize 页面",
      "purpose": "基于失败分析生成候选 Prompt 并查看回归结果",
      "entry_points": [
        "左侧导航",
        "Dashboard 进入 Optimize"
      ],
      "primary_actions": [
        "生成候选版本",
        "设为最佳候选",
        "保存优化方案"
      ],
      "states": [
        "normal",
        "candidate_selected"
      ]
    },
    {
      "screen_id": "compare",
      "screen_name": "Compare 页面",
      "purpose": "比较 Prompt 版本效果并形成发布建议",
      "entry_points": [
        "左侧导航",
        "Dashboard 版本 Compare"
      ],
      "primary_actions": [
        "查询对比",
        "查看详情",
        "一键发布新版"
      ],
      "states": [
        "normal",
        "release_recommended"
      ]
    },
    {
      "screen_id": "knowledge",
      "screen_name": "Knowledge 页面",
      "purpose": "沉淀规则、样例、失败模式和最佳实践",
      "entry_points": [
        "左侧导航"
      ],
      "primary_actions": [
        "切换知识类型",
        "导入",
        "导出",
        "收藏"
      ],
      "states": [
        "normal"
      ]
    },
    {
      "screen_id": "knowledge-detail",
      "screen_name": "知识条目详情",
      "purpose": "承载 Knowledge 表格“查看”动作，展示规则说明、推荐写法、适用条件、收益和关联资源",
      "entry_points": [
        "Knowledge 规则库查看按钮"
      ],
      "primary_actions": [
        "收藏",
        "基于此创建 Prompt",
        "查看关联 Dataset",
        "进入 Optimize"
      ],
      "states": [
        "normal",
        "context_from_selected_knowledge"
      ]
    },
    {
      "screen_id": "settings",
      "screen_name": "Settings 页面",
      "purpose": "管理用户、默认参数、模型、评测、导出和日志配置",
      "entry_points": [
        "左侧导航"
      ],
      "primary_actions": [
        "编辑资料",
        "保存设置",
        "备份配置"
      ],
      "states": [
        "normal"
      ]
    }
  ],
