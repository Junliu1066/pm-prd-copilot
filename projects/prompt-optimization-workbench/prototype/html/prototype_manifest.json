  "interaction_inventory": [
    {
      "interaction_id": "sidebar_navigation",
      "trigger": "点击左侧导航",
      "from_screen": "any",
      "result": "navigate",
      "target": "对应 data-screen 页面"
    },
    {
      "interaction_id": "top_new_run",
      "trigger": "点击顶部新建 Run",
      "from_screen": "any",
      "result": "navigate",
      "target": "runs"
    },
    {
      "interaction_id": "run_to_review",
      "trigger": "点击 Runs 页面提交人工评审",
      "from_screen": "runs",
      "result": "navigate",
      "target": "review"
    },
    {
      "interaction_id": "review_decision",
      "trigger": "点击 Review 页面评审决策按钮",
      "from_screen": "review",
      "result": "state_change",
      "target": "通过|有条件通过|不通过"
    },
    {
      "interaction_id": "review_submit",
      "trigger": "点击 Review 页面提交评审",
      "from_screen": "review",
      "result": "state_change",
      "target": "评审状态已提交"
    },
    {
      "interaction_id": "top_create_prompt",
      "trigger": "点击顶部创建 Prompt",
      "from_screen": "any",
      "result": "navigate",
      "target": "prompt-create"
    },
    {
      "interaction_id": "dashboard_quick_route",
      "trigger": "点击 Dashboard 快捷入口",
      "from_screen": "dashboard",
      "result": "navigate",
      "target": "datasets|optimize|compare|models"
    },
    {
      "interaction_id": "tab_switch",
      "trigger": "点击页签",
      "from_screen": "datasets|settings|knowledge",
      "result": "tab",
      "target": "当前页签高亮"
    },
    {
      "interaction_id": "knowledge_module_jump",
      "trigger": "点击 Knowledge 模块入口",
      "from_screen": "knowledge",
      "result": "state_change",
      "target": "规则库|样例库|失败模式库|最佳实践|Skill 候选池"
    },
    {
      "interaction_id": "table_row_select",
      "trigger": "点击表格查看按钮",
      "from_screen": "datasets",
      "result": "state_change",
      "target": "当前表格行选中"
    },
    {
      "interaction_id": "dataset_table_view",
      "trigger": "点击 Datasets 表格查看",
      "from_screen": "datasets",
      "result": "navigate",
      "target": "dataset-detail"
    },
    {
      "interaction_id": "dataset_table_edit",
      "trigger": "点击 Datasets 表格编辑",
      "from_screen": "datasets|dataset-detail",
      "result": "navigate",
      "target": "dataset-edit"
    },
    {
      "interaction_id": "knowledge_table_view",
      "trigger": "点击 Knowledge 规则库查看",
      "from_screen": "knowledge",
      "result": "navigate",
      "target": "knowledge-detail"
