{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewComment",
  "type": "object",
  "required": [
    "comment_id",
    "reviewer_role",
    "source",
    "comment_text"
  ],
  "properties": {
    "comment_id": {
      "type": "string"
    },
    "reviewer_role": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "comment_text": {
      "type": "string"
    },
    "section_ref": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "must_fix",
        "should_discuss",
        "nice_to_have",
        "out_of_scope",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "accepted",
        "rejected",
        "deferred"
      ]
    },
    "owner": {
      "type": "string"
    }
  },
  "additionalProperties": false
}