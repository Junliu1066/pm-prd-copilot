{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrackingPlan",
  "type": "object",
  "required": [
    "project_id",
    "metrics",
    "events"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "metric_type",
          "definition"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "metric_type": {
            "type": "string",
            "enum": [
              "north_star",
              "input",
              "guardrail"
            ]
          },
          "definition": {
            "type": "string"
          },
          "formula": {
            "type": "string"
          },
          "baseline": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "target": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "window": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "trigger",
          "properties"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "linked_metric": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "qa_method": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}