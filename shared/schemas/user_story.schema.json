{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserStory",
  "type": "object",
  "required": [
    "id",
    "persona",
    "need",
    "benefit",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "persona": {
      "type": "string"
    },
    "need": {
      "type": "string"
    },
    "benefit": {
      "type": "string"
    },
    "story_statement": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "p0",
        "p1",
        "p2",
        "p3"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "edge_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}